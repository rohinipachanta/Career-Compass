# Career Compass — Environment Variables
# Copy this to .env for local development
# Add these in Vercel → Settings → Environment Variables for deployment

# Your Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.kbmipbvexfylkltbpzcy.supabase.co:5432/postgres

# Session secret — make this a long random string (e.g. 32+ characters)
SESSION_SECRET=replace-this-with-a-long-random-secret-string

# Google AI (Gemini) API key — for AI coaching and review generation
# Free tier available — get your key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# ── Email forwarding (Postmark Inbound) ──────────────────────────────────────
# The inbound email address Postmark gives you (e.g. abc123@inbound.postmarkapp.com)
# Set as BOTH a server env var (used in logs) AND a Vite env var (shown in the UI)
INBOUND_EMAIL=abc123@inbound.postmarkapp.com
VITE_INBOUND_EMAIL=abc123@inbound.postmarkapp.com

# A random secret token to protect the inbound webhook URL
# Generate one at: https://www.uuidgenerator.net/ or run: openssl rand -hex 16
INBOUND_WEBHOOK_SECRET=replace-with-random-secret
